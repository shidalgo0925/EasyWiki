# EasyCoach / 1% Better App — Variables de Entorno
# Copiar a .env y completar valores reales

# Seguridad Flask (obligatorio)
SECRET_KEY=generar-con-python-secrets-token-hex-32

# Base de datos PostgreSQL
DATABASE_URL=postgresql+psycopg2://usuario:password@localhost:5432/easycoach_db

# Configuración Google OAuth2
CLIENT_SECRETS_FILE=client_secret.json
TOKEN_FILE=.secrets/token.json
OAUTH_REDIRECT_URI=https://tu-dominio.com/oauth2callback

# Zona horaria
LOCAL_TZ=America/Panama

# Debug (0 = producción, 1 = desarrollo)
SQL_ECHO=0

# --- IA / Coach Assistant ---
AI_PROVIDER=rules
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

AI_TIMEOUT_SECONDS=60
AI_MAX_TOKENS=1200
AI_TEMPERATURE=0.4
AI_FALLBACK_ENABLED=true
AI_FALLBACK_PROVIDERS=openai,ollama,rules

# Kimi (OpenAI-compatible)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama local
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b